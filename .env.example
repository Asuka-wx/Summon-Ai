# ============================================
# SummonAI MVP — 环境变量模板
# 复制为 .env.local 后填入实际值
# 命名规范：UPPER_SNAKE_CASE
# 前端可见变量统一使用 NEXT_PUBLIC_ 前缀
# ============================================

# === 区域选择（创建服务时配置，非环境变量）===
# Supabase: ap-southeast-1 (新加坡)
# Upstash Redis: ap-northeast-1 (东京)
# Fly.io: primary_region = "hkg" (香港)
# Cloudflare: 域名 NS 指向 Cloudflare，开启代理模式

# === 必填（无默认值，必须配置）===
# [V+F][public] Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [V+F][secret] Supabase
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# [V][secret/public] Web3 / Wallet
BASE_RPC_URL=
NEXT_PUBLIC_PLATFORM_DEPOSIT_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# [V][secret] 邮件 / 验证 / 定时任务 / 加密
RESEND_API_KEY=
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=
CRON_SECRET=
DATA_ENCRYPTION_MASTER_KEY=

# [V+F][secret] Redis / Relay
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RELAY_SECRET=
RELAY_INTERNAL_URL=

# [F][secret] Relay -> Vercel
VERCEL_API_URL=

# [V][public] 应用地址
NEXT_PUBLIC_APP_URL=https://summonai.xyz
NEXT_PUBLIC_WS_URL=wss://ws.summonai.xyz
NEXT_PUBLIC_SSE_URL=https://sse.summonai.xyz
#
# [local/script] Early-access Tally sync
TALLY_API_KEY=
TALLY_WORKSPACE_ID=
TALLY_EARLY_ACCESS_REDIRECT_URL=https://summonai.xyz

# [V][public] Early access intake（按语言 + 角色分别配置）
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_URL_ZH_BUYER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_ID_ZH_BUYER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_URL_ZH_BUILDER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_ID_ZH_BUILDER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_URL_EN_BUYER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_ID_EN_BUYER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_URL_EN_BUILDER=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_ID_EN_BUILDER=

# [V][public] Early access intake（兼容旧单表单配置）
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_URL=
NEXT_PUBLIC_TALLY_EARLY_ACCESS_FORM_ID=

# === 有默认值（可选覆盖）===

# [V][public] Web3
NEXT_PUBLIC_CHAIN_ENV=testnet

# [V][secret] Web3
BASE_RPC_FALLBACK_URL=https://mainnet.base.org

# [V][secret] 邮件
RESEND_FROM_EMAIL=noreply@summonai.xyz
EMAIL_RETRY_MAX=2

# [V][secret] hCaptcha
LOGIN_CAPTCHA_FAIL_THRESHOLD=5
CAPTCHA_BROADCAST_THRESHOLD=3
CAPTCHA_WINDOW_MINUTES=5

# [V][secret] SDK 安全
SDK_MIN_VERSION=1.0.0

# [V][secret] Cron 定时任务
HEALTH_RECALC_BATCH_SIZE=50
SETTLEMENT_CONFIRM_BATCH_SIZE=20
CONVERSATION_CLEANUP_INTERVAL_MINUTES=60

# [V][secret] 并发信誉
INITIAL_CONCURRENCY_LEVEL=1
MAX_CONCURRENCY_LEVEL=5
CONCURRENCY_HEALTH_THRESHOLD=80
CONCURRENCY_FAULT_THRESHOLD=0.10
CONCURRENCY_OBSERVATION_WINDOW=10
CONCURRENCY_DOWNGRADE_HEALTH=60
RETIRING_MAX_DAYS=7

# [V][secret] 支付与计费
PLATFORM_FEE_RATE=0.00
FREE_ROUNDS=3
MIN_BALANCE_ROUNDS=10
MIN_WITHDRAWAL_AMOUNT=5.00
WITHDRAWAL_FEE=0.10
DEPOSIT_CONFIRMATIONS=3
STUCK_WITHDRAWAL_MINUTES=30
GAS_WARN_THRESHOLD_ETH=0.002
GAS_CRITICAL_THRESHOLD_ETH=0.0005
GAS_PRICE_SPIKE_GWEI=0.5
GAS_SPIKE_RETRY_DELAY_MS=300000
GAS_SPIKE_MAX_RETRIES=3
WALLET_CHANGE_COOLDOWN_HOURS=48
MAX_TIP_AMOUNT=50.00
MIN_TIP_AMOUNT=0.01

# [V][secret] 隐私与安全
CONVERSATION_DELETE_HOURS=24
DELETION_WARNING_HOURS=4
REPORT_PRIVACY_THRESHOLD=3
REPORT_DISMISS_THRESHOLD=3
BALANCE_FREEZE_DAYS=30
SOCIAL_UNBIND_COOLDOWN_HOURS=48
SOCIAL_UNBIND_MAX_TIMES=3

# [V][secret] Admin 安全
ADMIN_SESSION_MAX_AGE_HOURS=4
ADMIN_2FA_REQUIRED=true
ADMIN_LOGIN_ALERT=true
ADMIN_LOGIN_LOCKOUT_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=30

# [V/F][secret] 安全 / 反滥用
GLOBAL_BROADCAST_RATE_LIMIT=200
SSE_MAX_CONNECTIONS_PER_IP=10
WS_MAX_CONNECTIONS_PER_IP=5
KEY_ROTATION_DAYS=90
CIRCULAR_TX_THRESHOLD_PERCENT=10
RAPID_COMPLETION_THRESHOLD_SECONDS=60
RAPID_COMPLETION_AMOUNT_LIMIT=100
ADMIN_ALLOWED_IPS=""
HIGH_FREQ_BROADCAST_THRESHOLD=5
HIGH_FREQ_BROADCAST_MIN_AMOUNT=1
LINKED_WALLET_THRESHOLD=3

# [V+F][secret] 任务生命周期
DISCONNECT_GRACE_SECONDS=60
CONSECUTIVE_TIMEOUT_LIMIT=3
CONFIRMATION_TIMEOUT_MINUTES=10
BROADCAST_SELECTION_TIMEOUT_MINUTES=10
IDLE_PAUSE_MINUTES=15
MAX_ACTIVE_TASKS_PER_USER=5
MAX_PLATFORM_CONCURRENT_TASKS=50
MAX_REPORTS_PER_USER_PER_DAY=3
MESSAGE_MAX_LENGTH=16000
IDLE_WARNING_MINUTES=10
AGENT_RESUME_WAIT_MINUTES=15
INSUFFICIENT_BALANCE_GRACE_MINUTES=10
AGENT_OFFLINE_AUTO_END_HOURS=24
PAUSE_EXPIRY_DAYS=3
CONFIRMATION_DISCONNECT_TIMEOUT_MINUTES=10

# [V][secret] Feature Flags
FF_PAYMENT_ENABLED=true
FF_WITHDRAWAL_ENABLED=true
FF_NOTIFICATION_EMAIL=true
FF_LEADERBOARD_ENABLED=true

# [V/F][secret/public] 故障处理 / 心跳 / 监控
HEARTBEAT_INTERVAL_SECONDS=15
HEARTBEAT_MISS_THRESHOLD=2
AGENT_RESPONSE_TIMEOUT_SECONDS=60
SSE_BUFFER_MINUTES=5
SUPABASE_KEEPALIVE_INTERVAL_DAYS=2
FLYIO_HEALTH_CHECK_PATH=/health
FLYIO_HEALTH_CHECK_INTERVAL=30
ALERT_EMAIL=admin@summonai.xyz
NEXT_PUBLIC_SENTRY_DSN=""

# [V][secret] 通知
NOTIFICATION_POLL_INTERVAL_SECONDS=30
WEEKLY_REPORT_ENABLED=true

# [F][secret] Fly.io Relay
PORT=8080
GRACEFUL_SHUTDOWN_TIMEOUT_MS=5000

# [V][secret] 供给侧质量
QUALITY_WARN_THRESHOLD=60
QUALITY_FAILURE_RATE_THRESHOLD=0.20
QUALITY_OBSERVE_WEEKS=3
QUALITY_MIN_TASKS=10
QUALITY_RECOVERY_WEEKS=2
QUALITY_RECOVERY_THRESHOLD=80
SEED_TASK_LIMIT=5
SEED_MAX_ROUNDS=15
SEED_RATING_WEIGHT=0.7

# [V][secret/public] 激活码系统（M-IC）
INVITATION_CODE_ENABLED=true
INVITATION_CODE_MAX_ATTEMPTS=5
